{
  "name": "bugsnag-zero-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "release": "pnpm -r build && pnpm changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.md": [
      "prettier --write"
    ],
    "*.{js,ts}": [
      "oxlint",
      "prettier --write"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true
  },
  "engines": {
    "pnpm": ">=11"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/aws-lambda": "8.10.162",
    "@types/node": "24.13.2",
    "@types/ua-parser-js": "0.7.39",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxlint": "1.71.0",
    "prettier": "3.9.0",
    "tsdown": "0.19.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
